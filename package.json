{
  "name": "carbcycle-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:reset": "rm -rf .next && next dev",
    "build": "next build",
    "check:env": "tsx scripts/check-env.ts",
    "check:env:prod": "tsx scripts/check-env.ts --prod",
    "check:db": "tsx scripts/check-db.ts",
    "build:prod": "npm run check:env:prod && PRISMA_SCHEMA_PATH=prisma/schema.postgres.prisma prisma generate && next build",
    "prepare:standalone": "mkdir -p .next/standalone/.next .next/standalone/node_modules/.prisma/client && rm -rf .next/standalone/public .next/standalone/.next/static && cp -R public .next/standalone/public && cp -R .next/static .next/standalone/.next/static && if [ -f prisma/dev.db ]; then cp prisma/dev.db .next/standalone/node_modules/.prisma/client/dev.db; fi",
    "start": "npm run prepare:standalone && node .next/standalone/server.js",
    "start:prod": "npm run check:env:prod && npm run prepare:standalone && node .next/standalone/server.js",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:generate:prod": "PRISMA_SCHEMA_PATH=prisma/schema.postgres.prisma prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "PRISMA_SCHEMA_PATH=prisma/schema.postgres.prisma prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^14.2.28",
    "next-pwa": "^5.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.5.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.49",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
