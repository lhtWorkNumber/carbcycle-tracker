.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 56rpx 40rpx;
  background: linear-gradient(180deg, #ecfeff 0%, #f8fafc 42%, #f8fafc 100%);
}

.brand {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 64rpx;
}

.mark {
  display: flex;
  width: 88rpx;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: #0f172a;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 700;
}

.eyebrow {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.4;
}

.title {
  color: #0f172a;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.panel {
  border: 1rpx solid #e2e8f0;
  border-radius: 24rpx;
  background: #ffffff;
  padding: 40rpx;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
}

.panel-title {
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}

.panel-copy {
  margin-top: 16rpx;
  color: #475569;
  font-size: 28rpx;
  line-height: 1.7;
}

.primary {
  display: flex;
  height: 96rpx;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  border-radius: 18rpx;
  background: #0891b2;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.primary[disabled] {
  background: #cbd5e1;
  color: #64748b;
}

.notice {
  margin-top: 24rpx;
  color: #b45309;
  font-size: 24rpx;
  line-height: 1.6;
}
